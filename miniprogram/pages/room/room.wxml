<!--pages/room/room.wxml-->
<view class="container">
  <view class="card">
    <view class="flex-between">
      <view>
        <view class="subtitle">房间号: {{roomId}}</view>
        <view class="text-muted">房主{{isHost ? '(您)' : ''}}可开始游戏</view>
      </view>
      <view>
        <button size="mini" class="btn btn-secondary" bindtap="copyRoomId">复制</button>
        <button size="mini" class="btn btn-primary" style="margin-left: 20rpx;" bindtap="shareRoom">邀请</button>
      </view>
    </view>

    <view style="margin-top: 30rpx;">
      <view class="text-muted">游戏状态: {{gameStarted ? '游戏中' : '等待中'}}</view>
      <view class="text-muted">玩家: {{players.length}}/12</view>
    </view>
  </view>

  <view class="card">
    <view class="flex-between">
      <view class="subtitle">玩家列表</view>
      <view wx:if="{{!gameStarted && currentUser}}" class="seat-btn" bindtap="changeSeatNumber">
        📍 更换座位
      </view>
    </view>

    <view wx:if="{{players.length === 0}}" class="text-center text-muted" style="padding: 60rpx;">
      等待玩家加入...
    </view>
    <view wx:else class="player-list">
      <view wx:for="{{players}}" wx:key="openId" class="player-item">
        <view class="flex-center">
          <view class="seat-badge {{item.seatNumber === seatNumber ? 'current' : ''}}">
            {{item.seatNumber}}号
          </view>
          <image src="{{item.avatarUrl}}" class="player-avatar"></image>
          <view class="player-info">
            <view class="player-name">
              {{item.seatNumber}}号玩家
              <text wx:if="{{item.openId === userInfo.openId}}" class="self-tag">（我）</text>
            </view>
            <view class="text-muted" style="font-size: 24rpx;">
              {{readyPlayers.includes(item.openId) ? '✓ 已准备' : '○ 未准备'}}
            </view>
          </view>
        </view>
        <view>
          <view wx:if="{{isHost && item.openId !== userInfo.openId}}" class="btn btn-danger btn-small" bindtap="kickPlayer" data-id="{{item.openId}}">踢出</view>
        </view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="subtitle">游戏控制</view>

    <view wx:if="{{!isHost && !gameStarted}}">
      <view class="current-seat-info">
        <text>当前座位：</text>
        <text class="seat-highlight">{{seatNumber}}号</text>
      </view>
      <button class="btn {{readyPlayers.includes(userInfo.openId) ? 'btn-secondary' : 'btn-primary'}}" bindtap="toggleReady">
        {{readyPlayers.includes(userInfo.openId) ? '取消准备' : '准备游戏'}}
      </button>
      <view class="text-muted text-center mt-2">
        等待房主开始游戏... {{readyPlayers.length}}/{{players.length}} 已准备
      </view>
    </view>

    <view wx:if="{{isHost && !gameStarted}}">
      <view class="current-seat-info">
        <text>我的座位：</text>
        <text class="seat-highlight">{{seatNumber}}号</text>
      </view>
      <button class="btn btn-success" bindtap="startGame" disabled="{{readyPlayers.length < players.length || players.length < 5}}">
        开始游戏
      </button>
      <view class="text-muted text-center mt-2">
        条件: {{readyPlayers.length}}/{{players.length}} 已准备, 至少5人
      </view>
      <view wx:if="{{readyPlayers.length < players.length}}" class="text-muted text-center mt-1">
        还有{{players.length - readyPlayers.length}}人未准备
      </view>
      <view wx:if="{{players.length < 5}}" class="text-muted text-center mt-1">
        还需要{{5 - players.length}}人才能开始
      </view>
    </view>

    <view wx:if="{{gameStarted}}" class="text-center">
      <view class="subtitle theme-primary">游戏已开始</view>
      <view class="text-muted">正在跳转到游戏界面...</view>
    </view>
  </view>

  <view class="card">
    <view class="subtitle">游戏提示</view>
    <view style="font-size: 28rpx;">
      <view>• 阿瓦隆支持5-12人游戏</view>
      <view>• 每位玩家都有唯一座位号(1-12号玩家)</view>
      <view>• 好人阵营需要完成3个任务</view>
      <view>• 坏人阵营可以破坏任务或刺杀梅林</view>
      <view>• 游戏过程中请勿退出，否则会影响其他玩家</view>
    </view>
  </view>

  <view wx:if="{{showSeatModal}}" class="modal-mask" bindtap="hideSeatModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-title">选择座位号</view>
      <view class="seat-grid">
        <view
          wx:for="{{12}}"
          wx:key="index"
          class="seat-item {{occupiedSeats.includes(index + 1) ? 'occupied' : ''}}"
          bindtap="selectSeat"
          data-seat="{{index + 1}}"
        >
          {{index + 1}}号
        </view>
      </view>
      <view class="modal-tip">灰色表示已被占用</view>
      <button class="btn btn-secondary" bindtap="hideSeatModal">取消</button>
    </view>
  </view>
</view>
