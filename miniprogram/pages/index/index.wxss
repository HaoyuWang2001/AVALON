/* pages/index/index.wxss */

.page {
  height: 100vh;
  background: linear-gradient(180deg, #F9FAFB 0%, #F3F4F6 100%);
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.logo-section {
  padding: 32rpx 0 20rpx;
  text-align: center;
  flex-shrink: 0;
}

.logo-icon {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 24rpx;
  background: linear-gradient(135deg, #8B5CF6, #6D28D9);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(124,58,237,0.25);
}

.logo-icon text {
  font-size: 60rpx;
}

.logo-title {
  font-size: 48rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #7C3AED, #5B21B6);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 6rpx;
}

.logo-subtitle {
  font-size: 26rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
  letter-spacing: 4rpx;
}

.user-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.user-info-section {
  width: 100%;
}

.user-left {
  display: flex;
  align-items: center;
}

.user-details {
  margin-left: 24rpx;
  flex: 1;
}

.user-name-row {
  display: flex;
  align-items: center;
}

.user-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.edit-btn {
  font-size: 32rpx;
  margin-left: 16rpx;
  padding: 8rpx;
  opacity: 0.7;
}

.edit-btn:active {
  opacity: 1;
}

.user-status {
  font-size: 24rpx;
  color: #10B981;
  margin-top: 4rpx;
  display: flex;
  align-items: center;
}

.user-status::before {
  content: '';
  width: 10rpx;
  height: 10rpx;
  background: #10B981;
  border-radius: 50%;
  margin-right: 8rpx;
}

.login-btn {
  width: 100%;
  background: linear-gradient(135deg, #8B5CF6, #6D28D9);
  color: white;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(124,58,237,0.3);
}

.login-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.action-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  flex-shrink: 0;
}

.action-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.action-title::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #8B5CF6, #6D28D9);
  border-radius: 3rpx;
  margin-right: 14rpx;
}

.action-btn {
  width: 100%;
  padding: 22rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.action-btn:last-child {
  margin-bottom: 0;
}

.action-btn-primary {
  background: linear-gradient(135deg, #8B5CF6, #6D28D9);
  color: white;
  box-shadow: 0 6rpx 20rpx rgba(124,58,237,0.3);
}

.action-btn-primary::after {
  border: none;
}

.action-btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(124,58,237,0.2);
}

.action-btn-secondary {
  background: #F9FAFB;
  color: #374151;
  border: 2rpx solid #E5E7EB;
}

.action-btn-secondary::after {
  border: none;
}

.action-btn-secondary:active {
  background: #F3F4F6;
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 14rpx;
}

.info-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  flex-shrink: 0;
}

.info-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 16rpx;
}

.info-item {
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.8;
}

.footer {
  text-align: center;
  padding: 16rpx 0;
  color: #D1D5DB;
  font-size: 22rpx;
  flex-shrink: 0;
}

.footer-version {
  color: #E5E7EB;
}
