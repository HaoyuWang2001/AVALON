# AVALON游戏服务器环境配置
# 复制此文件为.env并修改配置

# 服务器监听端口
PORT=8082

# MySQL 数据库配置
DB_HOST=127.0.0.1                 # 数据库主机地址（localhost）
DB_PORT=3307                      # 数据库端口（MySQL容器映射到主机的端口）
DB_USER=avalon_user               # 数据库用户名（在部署步骤中创建）
DB_PASS=<your_secure_password_here> # 数据库密码（替换为实际密码）
DB_NAME=avalon_db                 # 数据库名称

# 数据库连接池配置
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_IDLE=30000
DB_POOL_ACQUIRE=30000
DB_POOL_EVICT=60000

# 服务器配置
NODE_ENV=development
LOG_LEVEL=info

# WebSocket配置
WS_HEARTBEAT_INTERVAL=25000
WS_HEARTBEAT_TIMEOUT=60000

# 游戏配置
MAX_ROOMS=1000
MAX_PLAYERS_PER_ROOM=12
ROOM_TIMEOUT_HOURS=24
GAME_TIMEOUT_HOURS=2